\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces SOM response curves for \textit  {Ammophila arenaria} derived from SUSANA common-garden treatment means. Grey points show individual plant-level observations; coloured points with error bars show treatment means $\pm $ SE; solid lines show the fitted Gaussian (a--c) and logistic (d) curves. (a)~Height growth shows a broad optimum at $\mu = 1.32$\,\% TOC. (b)~Density growth: one extreme measurement removed (see text); no significant SOM effect. (c)~Root biomass growth peaks at $\mu = 1.24$\,\% TOC. (d)~Mortality shows no significant SOM effect ($\beta _1 = 0.010$, $p = 0.97$).}}{23}{figure.caption.9}\protected@file@percent }
\newlabel{fig:som_response_R_derivation}{{4}{23}{SOM response curves for \textit {Ammophila arenaria} derived from SUSANA common-garden treatment means. Grey points show individual plant-level observations; coloured points with error bars show treatment means $\pm $ SE; solid lines show the fitted Gaussian (a--c) and logistic (d) curves. (a)~Height growth shows a broad optimum at $\mu = 1.32$\,\% TOC. (b)~Density growth: one extreme measurement removed (see text); no significant SOM effect. (c)~Root biomass growth peaks at $\mu = 1.24$\,\% TOC. (d)~Mortality shows no significant SOM effect ($\beta _1 = 0.010$, $p = 0.97$)}{figure.caption.9}{}}
\newlabel{fig:som_response_R_derivation@cref}{{[figure][4][]4}{[1][22][]23}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Parameterised SOM response curves as implemented in the Living Dunes vegetation model. (a)~Process-specific Gaussian boost curves for height growth and the root-proxy processes lateral spread and shoot formation, derived from the experimental fits in \cref  {fig:som_response_R_derivation}. (b)~Geometric mean of all active SOM factors, representing the combined growth multiplier applied in the model. Shaded band: experimental SOM range (0.10--3.72\,\% SOM; 0.06--2.16\,\% TOC). Vertical dotted line: reference beach sand baseline (substrate R, 0.10\,\% SOM). Curves use the anchored boost formulation $f(\mathrm  {SOM})/f(\mathrm  {SOM}_{\mathrm  {ref}})$, which guarantees $f(\mathrm  {SOM}_{\mathrm  {ref}})=1$ exactly. Density growth SOM factor excluded (non-significant after removal of one extreme measurement).}}{24}{figure.caption.10}\protected@file@percent }
\newlabel{fig:som_response_modelled}{{5}{24}{Parameterised SOM response curves as implemented in the Living Dunes vegetation model. (a)~Process-specific Gaussian boost curves for height growth and the root-proxy processes lateral spread and shoot formation, derived from the experimental fits in \cref {fig:som_response_R_derivation}. (b)~Geometric mean of all active SOM factors, representing the combined growth multiplier applied in the model. Shaded band: experimental SOM range (0.10--3.72\,\% SOM; 0.06--2.16\,\% TOC). Vertical dotted line: reference beach sand baseline (substrate R, 0.10\,\% SOM). Curves use the anchored boost formulation $f(\mathrm {SOM})/f(\mathrm {SOM}_{\mathrm {ref}})$, which guarantees $f(\mathrm {SOM}_{\mathrm {ref}})=1$ exactly. Density growth SOM factor excluded (non-significant after removal of one extreme measurement)}{figure.caption.10}{}}
\newlabel{fig:som_response_modelled@cref}{{[figure][5][]5}{[1][22][]24}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Derived SOM response parameters for the Living Dunes vegetation model. Growth responses use a Gaussian function as a multiplier on the base demographic rate. Mortality uses a sigmoid (inverse logistic) function. Density growth is excluded from the model parameterisation due to a single outlier driving the apparent response.}}{25}{table.caption.8}\protected@file@percent }
\newlabel{tab:som_derived_parameters}{{2}{25}{Derived SOM response parameters for the Living Dunes vegetation model. Growth responses use a Gaussian function as a multiplier on the base demographic rate. Mortality uses a sigmoid (inverse logistic) function. Density growth is excluded from the model parameterisation due to a single outlier driving the apparent response}{table.caption.8}{}}
\newlabel{tab:som_derived_parameters@cref}{{[table][2][]2}{[1][22][]25}{}{}{}}
