# anova
l = aov(length ~ substrate * t, data = bakken)
Anova(l, type="III") # tot nu toe effect van substraat en t, geen interactie
# post-hoc test
TukeyHSD(l)
# anova
l = aov(length ~ substrate + t, data = bakken)
# post-hoc test
TukeyHSD(l)
n = aov(nr ~ substrate * t, data = bakken)
Anova(n, type="III") # tot nu toe effect van substraat en t,
n = aov(nr ~ substrate + t, data = bakken)
Anova(n, type="III") # tot nu toe effect van substraat en t,
# sign substr: R-D R-87.5 R-75 R-62.5 R-37.5 R-25 R-12.5 R-50 R-37.5 R-25 R-12.5
#               50-75 50-62.5 25-50 12.5-50 W-50
#               37.5-75 37.5-62.5 25-37.5 W-37.5
TukeyHSD(n)
